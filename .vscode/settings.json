{
  // formatter
  "editor.formatOnSave": true, // ファイル保存時の自動フォーマット有効
  "editor.formatOnPaste": true, // ペーストした文字の自動フォーマット有効
  "editor.formatOnType": true, // 文字入力行の自動フォーマット有効
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode", // ファイル保存時のフォーマット指定
  "extensions.ignoreRecommendations": false, // 拡張機能のおすすめを表示
  "files.exclude": {
    ".nuxt": true
    // "node_modules": true
  },
  "cSpell.words": [
    "clazz",
    "clsl",
    "heroicons",
    "izumi",
    "joyfullhonda",
    "Nuxt",
    "rfukuma",
    "Sensy",
    "skus"
  ]
}
