{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:develop": "node -e \"require('fs').copyFileSync('./.env.develop', './.env')\" && nuxt build",
    "build:staging-jh": "node -e \"require('fs').copyFileSync('./.env.staging-jh', './.env')\" && nuxt build",
    "build:staging-mitsubishi": "node -e \"require('fs').copyFileSync('./.env.staging-mitsubishi', './.env')\" && nuxt build",
    "build:production-jh": "node -e \"require('fs').copyFileSync('./.env.production-jh', './.env')\" && nuxt build",
    "build:production-izumi": "node -e \"require('fs').copyFileSync('./.env.production-izumi', './.env')\" && nuxt build",
    "build:production-mitsubishi": "node -e \"require('fs').copyFileSync('./.env.production-mitsubishi', './.env')\" && nuxt build",
    "start": "nuxt start",
    "dev": "yarn install && node -e \"require('fs').copyFileSync('./.env.local', './.env')\" && nuxt dev --port 3001",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint --ext \".js,.ts,.vue\" --ignore-path .gitignore .",
    "lintfix": "prettier --write --list-different . && npm run lint -- --fix"
  },
  "dependencies": {
    "@kgierke/nuxt-basic-auth": "^1.5.0",
    "@nuxt/ui": "^2.15.1",
    "@sidebase/nuxt-auth": "^0.6.7",
    "@types/file-saver": "^2.0.7",
    "date-fns": "^3.6.0",
    "file-saver": "^2.0.5",
    "jsonwebtoken": "^9.0.2",
    "nuxt": "^3.10.3",
    "v-calendar": "^3.1.2",
    "vue": "^3.4.19",
    "vue-router": "^4.3.0",
    "vue3-dropzone": "^2.2.1",
    "vue3-toastify": "^0.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^0.2.0",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/eslint-module": "^4.1.0",
    "@nuxtjs/tailwindcss": "^6.11.4",
    "@types/": "sidebase/nuxt-auth",
    "@types/jsonwebtoken": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.22.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "sass": "^1.71.1",
    "typescript": "^5.3.3"
  }
}
